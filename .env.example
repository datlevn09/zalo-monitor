# ═══════════════════════════════════════════════════════════════════════════
# Zalo Monitor — .env cho docker-compose (dev + prod)
#
# Copy thành .env rồi điền giá trị. File .env KHÔNG commit (đã .gitignore).
# Với deploy production, dùng docker-compose.prod.yml.
# ═══════════════════════════════════════════════════════════════════════════

# ── DB & Cache ────────────────────────────────────────────────────────────
POSTGRES_DB=zalomonitor
POSTGRES_USER=zalomonitor
POSTGRES_PASSWORD=                    # BẮT BUỘC — đặt password mạnh cho prod

# ── Security (BẮT BUỘC) ───────────────────────────────────────────────────
# Sinh bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=                       # Fallback secret global; webhook chính đã dùng per-tenant secret tự sinh
JWT_SECRET=                           # Ký JWT đăng nhập dashboard khách
SUPER_ADMIN_TOKEN=                    # Token truy cập /super-admin — giữ BÍ MẬT TUYỆT ĐỐI

# ── Ports ─────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
DASHBOARD_PORT=3000

# ── URLs ──────────────────────────────────────────────────────────────────
# Prod: HTTPS domain công khai; Dev: http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
# Khi backend đứng sau reverse proxy (Caddy/Nginx), set domain thật để installer
# sinh URL đúng cho khách
PUBLIC_BACKEND_URL=

# ── AI (tùy chọn) ─────────────────────────────────────────────────────────
# Không set = AI classify dùng keyword fallback (không gọi API trả phí)
ANTHROPIC_API_KEY=

# ── Domain cho Caddy (production) ─────────────────────────────────────────
# docker-compose.prod.yml đọc biến này để phát hành HTTPS tự động
DOMAIN=
LETSENCRYPT_EMAIL=

# ── OpenClaw integration ──────────────────────────────────────────────────
# Tên container OpenClaw trên host backend (để sync groups / avatars qua docker exec)
OPENCLAW_CONTAINER=openclaw

# ── Publisher contact (hiển thị cho khách trong modal "Cần hỗ trợ?") ──────
# Bỏ trống nếu không muốn hiện.
ADMIN_NAME=
ADMIN_ZALO=
ADMIN_TELEGRAM=
ADMIN_EMAIL=

# ── Telegram admin bot (tùy chọn, cho reseller dùng riêng) ────────────────
# Chỉ set nếu BẠN (reseller) muốn admin DM bot để query dashboard qua Telegram.
# KHÔNG cần cho khách — tin nhắn khách forward qua OpenClaw hook của họ.
# Lấy token từ @BotFather nếu cần.
TELEGRAM_BOT_TOKEN=
