# Domain của bạn (ví dụ: zalo.congty.com)
DOMAIN=your-domain.com

# License key từ nhà cung cấp
LICENSE_KEY=your-license-key-here

# Mật khẩu database (tạo ngẫu nhiên, ví dụ: openssl rand -hex 16)
POSTGRES_PASSWORD=change-me-strong-password

# JWT secret (tạo ngẫu nhiên: openssl rand -hex 32)
JWT_SECRET=change-me-jwt-secret

# Webhook secret cho OpenClaw hook (tạo ngẫu nhiên: openssl rand -hex 16)
WEBHOOK_SECRET=change-me-webhook-secret

# Super admin token để quản lý các tenant trên máy chủ (tạo ngẫu nhiên: openssl rand -hex 16)
SUPER_ADMIN_TOKEN=change-me-super-admin-token

# Anthropic API key (tùy chọn - để trống nếu không dùng AI)
ANTHROPIC_API_KEY=

# Telegram bot token (tùy chọn - để trống nếu không dùng thông báo Telegram)
TELEGRAM_BOT_TOKEN=

# Thông tin admin hỗ trợ (hiển thị trong wizard cài đặt)
ADMIN_NAME=Support
ADMIN_ZALO=
ADMIN_TELEGRAM=

# Database settings
POSTGRES_DB=zalomonitor
POSTGRES_USER=zalomonitor
