{$DOMAIN} {
    encode gzip zstd

    # WebSocket (socket.io)
    @ws {
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @ws {
        reverse_proxy backend:3001
    }

    # Backend: API + webhook + health
    handle /api/* {
        reverse_proxy backend:3001
    }
    handle /webhook/* {
        reverse_proxy backend:3001
    }
    handle /health {
        reverse_proxy backend:3001
    }

    # Dashboard: tất cả còn lại
    handle {
        reverse_proxy dashboard:3000
    }
}
