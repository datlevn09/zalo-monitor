# Zalo Monitor backend — .env
# Copy thành .env rồi điền. KHÔNG commit file .env (đã .gitignore).

# ── Database + Cache ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://zalomonitor:CHANGE_ME@localhost:5433/zalomonitor
REDIS_URL=redis://localhost:6379

# ── Security (BẮT BUỘC) ───────────────────────────────────────────────────
# Mỗi biến sinh bằng:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=                       # fallback secret; webhook chính dùng per-tenant (tự sinh)
JWT_SECRET=                           # ký JWT đăng nhập dashboard
SUPER_ADMIN_TOKEN=                    # /super-admin access — giữ BÍ MẬT

# ── URLs ──────────────────────────────────────────────────────────────────
PORT=3001
# Khi backend đứng sau reverse proxy công khai (Caddy/Nginx), set domain HTTPS.
# Installer sinh cho khách sẽ dùng URL này thay cho localhost.
PUBLIC_BACKEND_URL=

# ── AI (tùy chọn) ─────────────────────────────────────────────────────────
# Không set → AI classify dùng keyword fallback (miễn phí, chính xác thấp hơn)
ANTHROPIC_API_KEY=

# ── OpenClaw integration ──────────────────────────────────────────────────
# Tên container OpenClaw nếu backend và OpenClaw đều chạy docker trên cùng host
OPENCLAW_CONTAINER=openclaw

# ── Publisher contact (hiển thị trong modal "Cần hỗ trợ?" của khách) ──────
ADMIN_NAME=
ADMIN_ZALO=
ADMIN_TELEGRAM=
ADMIN_EMAIL=

# ── Telegram admin bot (tùy chọn, chỉ cho reseller) ───────────────────────
# Cho phép admin DM bot để query stats qua Telegram.
# Không cần cho khách — hook OpenClaw đã đủ.
TELEGRAM_BOT_TOKEN=
